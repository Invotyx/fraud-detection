# =============================================================================
# Fraud Detection LLM — Environment Variables
# Copy to llm/.env and fill in real values before running deploy.sh.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# System / Python setup  (used by setup.sh)
# ---------------------------------------------------------------------------
PYTHON_VERSION=3.11
VENV_DIR=${HOME}/venv
CUDA_VERSION=12.1
CUDA_TOOLKIT_URL=https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2204/x86_64
PYTORCH_WHEEL_URL=https://download.pytorch.org/whl/cu121

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
BASE_MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct
FALLBACK_MODEL_ID=microsoft/Phi-3-mini-4k-instruct

# ---------------------------------------------------------------------------
# Dataset preparation  (used by prepare_data.py)
# ---------------------------------------------------------------------------
DATASET_COUNT=600
DATA_DIR=llm/data

# ---------------------------------------------------------------------------
# Training
# ---------------------------------------------------------------------------
RANDOM_SEED=42
WANDB_PROJECT=fraud-detection-llm
# WANDB_API_KEY=<your-wandb-key>        # required if report_to=wandb

# ---------------------------------------------------------------------------
# Checkpoints / paths
# ---------------------------------------------------------------------------
CHECKPOINTS_DIR=checkpoints
RUN1_CHECKPOINT=${CHECKPOINTS_DIR}/run1/final
RUN2_CHECKPOINT=${CHECKPOINTS_DIR}/run2/final
MERGED_DIR=${CHECKPOINTS_DIR}/final_merged

# ---------------------------------------------------------------------------
# Inference server  (used by merge_and_serve.py / eval.py / red_team.py)
# ---------------------------------------------------------------------------
LLM_SERVER_PORT=8001
LLM_SERVER_URL=http://localhost:${LLM_SERVER_PORT}
SERVER_STARTUP_WAIT_SECONDS=60

VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=4096
VLLM_DTYPE=float16

# ---------------------------------------------------------------------------
# Evaluation thresholds
# ---------------------------------------------------------------------------
SCORE_THRESHOLD=0.5
JSON_PARSE_TARGET=1.0
PER_PARAM_F1_TARGET=0.80
FP_RATE_TARGET=0.10
MIN_F1_TARGET=0.80
TARGETED_EXAMPLES_PER_PARAM=150
