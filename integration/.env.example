# =============================================================================
# Fraud Detection Integration — Environment Variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=fraud-detection-integration
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

API_TITLE=Fraud Detection Integration API
API_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://fraud:fraud@localhost:5432/fraud_detection

# ---------------------------------------------------------------------------
# Cache (Redis)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# LLM Inference Server
# ---------------------------------------------------------------------------
LLM_SERVER_URL=http://localhost:8001
LLM_REQUEST_TIMEOUT=10       # seconds

# Score blending: LLM vs rule-based (must sum to 1.0)
LLM_SCORE_WEIGHT=0.6
RULE_SCORE_WEIGHT=0.4

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
API_KEY_HEADER=X-API-Key
JWT_SECRET_KEY=change-me-in-production   # REQUIRED: change before deploying
JWT_ALGORITHM=HS256

# ---------------------------------------------------------------------------
# Risk Thresholds  (also tunable via configs/thresholds.yaml)
# ---------------------------------------------------------------------------
RISK_ALLOW_THRESHOLD=0.3
RISK_REVIEW_THRESHOLD=0.7

# ---------------------------------------------------------------------------
# Pipeline
# ---------------------------------------------------------------------------
PIPELINE_TIMEOUT_SECONDS=5.0

# Inline heuristic scores used before full URL-risk classifier runs
URL_RISK_SUSPICIOUS_SCORE=0.5
URL_RISK_DEFAULT_SCORE=0.05
INJECTION_ENCODING_ANOMALY_SCORE=0.6

# ---------------------------------------------------------------------------
# CORS  (comma-separated origins; * = allow all)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_WINDOW_SECONDS=60.0

# ---------------------------------------------------------------------------
# Human-in-the-Loop (HITL)
# ---------------------------------------------------------------------------
HITL_ESCALATION_TIMEOUT_SECONDS=3600
HITL_QUEUE_DEFAULT_LIMIT=20
